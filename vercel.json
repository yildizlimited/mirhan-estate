{
  "buildCommand": "pnpm install --frozen-lockfile=false && pnpm --filter @workspace/api-server run build:serverless && pnpm --filter @workspace/mirhan-estate run build:vercel",
  "outputDirectory": "artifacts/mirhan-estate/dist",
  "installCommand": "pnpm install --frozen-lockfile=false",
  "nodeVersion": "22.x",
  "functions": {
    "api/index.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index"
    },
    {
      "source": "/((?!api).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
